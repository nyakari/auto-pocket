{
    "name": "auto-pocket",
    "version": "0.1.4",
    "description": "OCR-based window automation library",
    "keywords": [
        "automation",
        "ocr",
        "screenshot",
        "windows"
    ],
    "license": "MIT",
    "author": "",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "make-ico": "node scripts/make-ico.mjs build/icon.png build/icon.ico",
        "build": "npm run build:lib && npm run build:electron",
        "build:lib": "tsc -p tsconfig.json",
        "build:electron": "tsc -p electron/tsconfig.json",
        "build:renderer": "cd src && npx vp build",
        "dev": "npm run build:lib && concurrently --kill-others \"npm run dev:renderer\" \"npm run dev:electron\"",
        "dev:renderer": "cd src && npx vp dev --port 5173",
        "dev:electron": "wait-on http://localhost:5173 && npx electron dist-electron/main.js --dev",
        "build:app": "npm run build && npm run build:renderer && npx electron-builder --win portable",
        "example": "npx tsx examples/rules.ts",
        "watch": "tsc --watch",
        "download-adb": "node scripts/setup-adb.mjs",
        "prepare": "npx vp config && npm run download-adb"
    },
    "dependencies": {
        "@atlaskit/pragmatic-drag-and-drop": "^1.8.1",
        "@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^2.1.5",
        "@atlaskit/pragmatic-drag-and-drop-flourish": "^2.0.15",
        "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
        "@nut-tree-fork/nut-js": "^4.2.6",
        "node-screenshots": "^0.2.8",
        "node-windows-ocr": "^1.1.1"
    },
    "devDependencies": {
        "@electron/rebuild": "^3.7.1",
        "@types/node": "^25.9.1",
        "@vitejs/plugin-vue": "^6.0.7",
        "concurrently": "^9.2.1",
        "electron": "^42.2.0",
        "electron-builder": "^26.8.1",
        "sharp": "^0.34.5",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3",
        "vite": "npm:@voidzero-dev/vite-plus-core@latest",
        "vite-plus": "latest",
        "vue": "^3.5.34",
        "wait-on": "^9.0.10"
    },
    "overrides": {
        "@electron/node-gyp": "10.2.0-electron.2",
        "vite": "npm:@voidzero-dev/vite-plus-core@latest"
    },
    "build": {
        "appId": "com.autopocket.app",
        "asar": true,
        "asarUnpack": [
            "**/node_modules/node-windows-ocr/**/*"
        ],
        "productName": "Auto Pocket",
        "icon": "build/icon.ico",
        "extraMetadata": {
            "main": "dist-electron/main.js"
        },
        "files": [
            "dist/**/*",
            "dist-electron/**/*",
            "src/dist/**/*",
            "node_modules/**/*"
        ],
        "extraResources": [
            {
                "from": "bin",
                "to": "bin",
                "filter": [
                    "adb.exe",
                    "AdbWinApi.dll",
                    "AdbWinUsbApi.dll"
                ]
            }
        ],
        "directories": {
            "output": "release"
        },
        "win": {
            "icon": "build/icon.ico",
            "target": [
                "portable"
            ]
        },
        "npmRebuild": false
    }
}
