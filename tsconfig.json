{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "declaration": true,
        "outDir": "./dist",
        "rootDir": "./lib",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "ignoreDeprecations": "6.0"
    },
    "include": ["lib/**/*", "src/global.d.ts"],
    "exclude": ["node_modules", "dist", "examples"]
}
